# local API credentials (never commit)
.together_key
.fireworks_key
.deepinfra_key

# session handoff scratch (untracked 2026-07-17; earlier revisions remain in git history intentionally)
HANDOFF.md

# local agent-harness state
.claude/

# ledger lock/reservation sidecars (transient)
runs/*.lock
runs/*.reservations

# Python envs / caches
.venv*/
__pycache__/
*.pyc

# Large data artifacts — regenerated on GPU; .pt files exceed GitHub's 100MB limit
*.pt

# Token-embedding matrices (extracted from HF weights; ~0.5-1GB each) — re-extractable, not committed.
# Live under artifacts/ (a dir labkit's rsync excludes by default) so the ~2GB isn't uploaded to the GPU box.
*_embed.npy
artifacts/

# exp2 generated analysis artifacts (regenerated by run_budget.py); the hand-written report .md IS tracked
experiments/exp2_output_monitorability/reports/budget_*.json
experiments/exp2_output_monitorability/reports/budget_*.png
# ...EXCEPT the small headline results that back the published tables -- committed so the writeup is
# self-verifiable from a bare checkout (no HF pull needed to diff a number against its source).
!experiments/exp2_output_monitorability/reports/budget_results.json

# exp3 generated analysis artifacts (regenerated by run_induction.py / gauge_judge.py; stored on HF);
# the hand-written report .md IS tracked. exp3_bundles.tar is box-shipping staging.
experiments/exp3_induction_and_scale/reports/induction_*
experiments/exp3_induction_and_scale/reports/gauge_*
experiments/exp3_induction_and_scale/reports/box/
runs/exp3_bundles.tar
# ...EXCEPT the small headline results behind the published arm + gauge tables (committed; see above).
!experiments/exp3_induction_and_scale/reports/induction_results.json
!experiments/exp3_induction_and_scale/reports/gauge_results.json
runs/exp2_bundles.tar
runs/reanalysis_box/
runs/reanalysis_resume/

# Logs / transient
*.log
run.log

# labkit run telemetry (status/events written per run; regenerated, not source)
runs/*status*.json
runs/*events*.jsonl

# Harness ledgers / secrets
*spend_ledger.json
.labkit_ledger.json
.config/
